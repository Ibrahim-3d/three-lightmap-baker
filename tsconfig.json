{
	"compilerOptions": {
		"module": "esnext",
		"target": "esnext",
		"baseUrl": ".",
		"paths": {
			"shared": ["packages/shared/src/index.ts"],
			"shared/*": ["packages/shared/src/*"],
			"baker-classic": ["packages/baker-classic/src/index.ts"],
			"baker-classic/ui": ["packages/baker-classic/src/ui/index.ts"],
			"demo-shell": ["packages/demo-shell/src/index.ts"],
			"pt-renderer": ["packages/pt-renderer/src/index.ts"],
			"pt-renderer/*": ["packages/pt-renderer/src/*"]
		},
		"lib": [
			"es2015",
			"ES2019",
			"DOM",
			"ES7"
		],
		"moduleResolution": "Node",
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"allowSyntheticDefaultImports": true,
		"experimentalDecorators": true,
		"alwaysStrict": false,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"exactOptionalPropertyTypes": false,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0"
	},
	"include": [
		"./packages/*/src/**/*",
		"./apps/*/src/**/*"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
